POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev_password

ENVIRONMENT=docker
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173

HEALTHCHECK_INTERVAL_SECONDS=60
HEALTHCHECK_TIMEOUT_SECONDS=5
DEGRADED_RESPONSE_TIME_MS=1000
ENABLE_HEALTHCHECK_WORKER=true

INITIAL_ADMIN_NAME=Sentinel Admin
INITIAL_ADMIN_EMAIL=admin@sentinel.local
INITIAL_ADMIN_PASSWORD=ChangeMe123!

LOG_LEVEL=INFO
NGINX_PORT=80
